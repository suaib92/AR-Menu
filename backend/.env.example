PORT=5000
MONGO_URI=mongodb://localhost:27017/arsmartmenu
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRE=30d
NODE_ENV=development

# Get your free API key from https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# NVIDIA NIM API (https://build.nvidia.com)
NVIDIA_API_KEY=your_nvidia_api_key_here

# Cloudinary (https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# VAPID keys for Web Push notifications
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# VAPID contact (RFC 8292 requires a mailto: or https: contact)
VAPID_CONTACT=mailto:admin@example.com

# Comma-separated allowed origins for CORS (no trailing slashes)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Trusted proxy count for express-rate-limit (0 = direct connection only)
TRUST_PROXY=0
